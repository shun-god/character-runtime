{
  "name": "character-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "start": "node --env-file-if-exists=.env --import tsx src/cli.ts",
    "evaluate": "node --env-file-if-exists=.env --import tsx scripts/evaluate.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
